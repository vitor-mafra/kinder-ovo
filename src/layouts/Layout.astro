---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Ranking e estatísticas do Momento Kinder Ovo no Foro de Teresina.",
} = Astro.props;
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <title>{title}</title>
  </head>
  <body>
    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-inner">

        <div class="footer-top">
          <a href="#" class="footer-back-btn" aria-label="Voltar ao início da página">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="18 15 12 9 6 15"/>
            </svg>
            Voltar ao início
          </a>
        </div>

        <div class="footer-bottom">
          <span class="footer-brand-name">Momento Kinder Ovo</span>
          <span class="footer-copyleft">
            <span class="copyleft-symbol" aria-label="Copyleft" title="Copyleft">©</span>
            Copyleft 2026 Vitor Mafra ·
            <a
              href="https://creativecommons.org/licenses/by-sa/4.0/deed.pt"
              target="_blank"
              rel="noopener noreferrer"
              class="footer-license-link"
            >CC BY-SA 4.0</a>
          </span>
        </div>

      </div>
    </footer>

    <style is:global>
      @import "../styles/global.css";
    </style>

    <style>
      .footer {
        background: var(--color-surface-low);
        border-top: 1px solid var(--color-outline-soft);
        margin-top: 96px;
        color: rgba(77, 59, 43, 0.8);
      }

      .footer-inner {
        max-width: var(--container-wide);
        margin: 0 auto;
        padding: 40px var(--page-padding) 36px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 28px;
      }

      /* ── Back to top button ── */
      .footer-back-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-family: var(--font-ui);
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--color-primary-deep);
        text-decoration: none;
        border: 1px solid var(--color-outline-soft);
        border-radius: 999px;
        padding: 10px 22px;
        background: var(--color-surface);
        transition: background 0.18s ease, border-color 0.18s ease, color 0.18s ease, transform 0.18s ease;
      }

      .footer-back-btn:hover {
        background: var(--color-egg-chocolate);
        border-color: var(--color-egg-chocolate);
        color: var(--color-bg);
        text-decoration: none;
        transform: translateY(-2px);
      }

      .footer-back-btn svg {
        transition: transform 0.18s ease;
      }

      .footer-back-btn:hover svg {
        transform: translateY(-2px);
      }

      /* ── Bottom row ── */
      .footer-bottom {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        text-align: center;
      }

      .footer-brand-name {
        font-family: var(--font-hero-display);
        font-size: 1.75rem;
        font-weight: 700;
        letter-spacing: -0.01em;
        text-transform: none;
        color: var(--color-primary-deep);
      }

      .footer-copyleft {
        font-family: var(--font-body);
        font-size: 0.9375rem;
        font-weight: 400;
        color: rgba(77, 59, 43, 0.5);
        letter-spacing: 0;
      }

      .copyleft-symbol {
        display: inline-block;
        transform: scaleX(-1);
        font-style: normal;
      }
      .footer-license-link {
        color: rgba(77, 59, 43, 0.65);
        text-decoration: underline;
        text-decoration-color: rgba(77, 59, 43, 0.25);
        text-underline-offset: 2px;
        transition: color 0.15s ease;
      }

      .footer-license-link:hover {
        color: var(--color-egg-chocolate);
        text-decoration-color: var(--color-egg-chocolate);
      }

      @media (max-width: 480px) {
        .footer-inner {
          gap: 24px;
          padding: 32px var(--page-padding) 28px;
        }
      }
    </style>
  </body>
</html>
