---
import figures from "../data/figures.json";
import episodes from "../data/episodes.json";
import spotifyMap from "../data/spotify-episodes.json";

const spotifyById = spotifyMap as Record<string, string>;

interface Figure {
  name: string;
  count: number;
  hitCount?: number;
  hitRate?: number;
  wikipediaUrl?: string;
  imageUrl?: string;
}

interface FigEpisodeRow {
  episodeNumber: number | null;
  title: string;
  dateLabel: string;
  spotifyUrl: string;
  winners: string[];
}

interface EpisodeRow {
  id: number;
  title: string;
  episodeNumber: number | null;
  publishedAt: string | null;
  hasKinderOvo?: boolean;
  publicFigure?: string | null;
  winners?: string[];
}

function spotifyEpisodeUrl(id: number, title: string): string {
  const sid = spotifyById[String(id)];
  return sid
    ? `https://open.spotify.com/episode/${sid}`
    : `https://open.spotify.com/search/${encodeURIComponent(title)}`;
}

function formatEpisodeDate(iso: string): string {
  const d = new Date(iso);
  return d.toLocaleDateString("pt-BR", {
    day: "2-digit",
    month: "short",
    year: "numeric",
  });
}

function splitPublicFigure(raw: string | null | undefined): string[] {
  if (!raw?.trim()) return [];
  return raw.split(";").map((s) => s.trim()).filter(Boolean);
}

/** Episódios onde cada figura aparece em publicFigure (ordenados por data). */
function buildFigureEpisodeIndex(eps: EpisodeRow[]): Record<string, FigEpisodeRow[]> {
  type Acc = FigEpisodeRow & { sortMs: number; id: number };
  const bucket: Record<string, Acc[]> = {};

  for (const ep of eps) {
    if (!ep.hasKinderOvo || !ep.publicFigure?.trim() || !ep.publishedAt) continue;
    const parts = splitPublicFigure(ep.publicFigure);
    if (parts.length === 0) continue;

    const sortMs = new Date(ep.publishedAt).getTime();
    const dateLabel = formatEpisodeDate(ep.publishedAt);
    const spotifyUrl = spotifyEpisodeUrl(ep.id, ep.title);
    const row: Acc = {
      id: ep.id,
      episodeNumber: ep.episodeNumber ?? null,
      title: ep.title,
      dateLabel,
      spotifyUrl,
      winners: ep.winners ?? [],
      sortMs,
    };

    for (const name of parts) {
      if (!bucket[name]) bucket[name] = [];
      const arr = bucket[name];
      if (!arr.some((x) => x.id === ep.id)) arr.push(row);
    }
  }

  const out: Record<string, FigEpisodeRow[]> = {};
  for (const [name, rows] of Object.entries(bucket)) {
    rows.sort((a, b) => a.sortMs - b.sortMs);
    out[name] = rows.map(({ id: _id, sortMs: _s, ...rest }) => rest);
  }
  return out;
}

/** Conta quantos episódios onde cada figura aparece tiveram pelo menos um ganhador. */
function buildFigureHitIndex(eps: EpisodeRow[]): Record<string, number> {
  const hits: Record<string, number> = {};
  for (const ep of eps) {
    if (!ep.hasKinderOvo || !ep.publicFigure?.trim()) continue;
    const parts = splitPublicFigure(ep.publicFigure);
    // considera acerto se houve ao menos um winner (excluindo empates sem vencedor)
    const wasHit = Array.isArray((ep as any).winners) && (ep as any).winners.length > 0;
    for (const name of parts) {
      if (wasHit) hits[name] = (hits[name] ?? 0) + 1;
    }
  }
  return hits;
}

const figureHitIndex = buildFigureHitIndex(episodes as EpisodeRow[]);

const allFigures: Figure[] = (figures as Figure[]).map((f) => {
  const hitCount = figureHitIndex[f.name] ?? 0;
  const hitRate = f.count > 0 ? Math.round((hitCount / f.count) * 100) : 0;
  return { ...f, hitCount, hitRate };
});
const INITIAL_SHOWN = 20;
const top = allFigures.slice(0, INITIAL_SHOWN);
const totalFigures = allFigures.length;

const figureEpisodeIndex = buildFigureEpisodeIndex(episodes as EpisodeRow[]);
---

<section class="top-figures" id="figuras">
  <h2 class="section-title">As surpresas mais frequentes</h2>

  <div class="figures-search-block">
    <label class="figures-search-label" for="figures-search">Buscar figura pública</label>
    <input
      id="figures-search"
      class="figures-search-input"
      type="search"
      name="figures-search"
      autocomplete="off"
      spellcheck="false"
      placeholder={`Buscar entre ${totalFigures} figuras públicas…`}
    />
    <p class="figures-search-hint" id="figures-search-hint">
      Exibindo as {INITIAL_SHOWN} mais frequentes. Use a busca para encontrar uma em específico.
    </p>
    <p class="figures-live" id="figures-live" role="status" aria-live="polite"></p>
  </div>

  <div class="figures-grid" id="figures-grid">
    {top.map((f, i) => (
      <article class="figure-card" data-figure-name={f.name} tabindex="0" role="button" aria-label={`Ver episódios com áudio de ${f.name}`}>
        <div class="figure-thumb">
          {f.imageUrl ? (
            <img
              src={f.imageUrl}
              alt={`Foto de ${f.name} (Wikipedia)`}
              loading="lazy"
            />
          ) : (
            <span class="figure-thumb-fallback" aria-hidden="true">
              {f.name.split(" ").map((p) => p[0]).slice(0, 2).join("").toUpperCase()}
            </span>
          )}
          <span class="figure-rank">{i + 1}</span>
        </div>

        <h3 class="figure-name">{f.name}</h3>

        <div class="figure-meta">
          <span class="figure-count">
            <strong>{f.count}</strong> {f.count === 1 ? "aparição" : "aparições"}
          </span>
          <span class="figure-hit-rate" title={`Acertada em ${f.hitCount} de ${f.count} episódio${f.count === 1 ? "" : "s"}`}>
            {f.hitRate}% de acerto
          </span>
        </div>
        {f.wikipediaUrl && (
          <div class="figure-wiki">
            <a
              class="figure-link"
              href={f.wikipediaUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              Wikipédia <span aria-hidden="true">↗</span>
            </a>
          </div>
        )}
      </article>
    ))}
  </div>

  <p class="figures-empty" id="figures-empty" hidden>
    Nenhuma figura encontrada com esse termo.
  </p>

  <div
    id="figure-episodes-tooltip"
    class="figure-episodes-tooltip"
    role="dialog"
    aria-hidden="true"
    aria-labelledby="fig-tt-name"
  >
    <h3 class="fig-tt-title" id="fig-tt-name"></h3>
    <p class="fig-tt-sub">Foi a surpresa do Kinder Ovo em:</p>
    <ul class="fig-tt-list" id="fig-tt-list"></ul>
  </div>
</section>

<script define:vars={{ allFigures, totalFigures, INITIAL_SHOWN, figureEpisodeIndex }}>
  /** Normaliza texto para busca: sem acentos, minúsculas, pontuação virando espaço. */
  function normalize(str) {
    return str
      .normalize("NFD")
      .replace(/\p{M}/gu, "")
      .toLowerCase()
      .replace(/[^a-z0-9\s]/g, " ")
      .replace(/\s+/g, " ")
      .trim();
  }

  /** Correspondência por substring ou por tokens (ex.: "S. Neves" → só exige "neves"). */
  function nameMatchesQuery(nameNorm, queryNorm) {
    if (!queryNorm) return true;
    if (nameNorm.includes(queryNorm)) return true;
    const tokens = queryNorm.split(/\s+/).filter((t) => t.length >= 2);
    if (tokens.length === 0) return nameNorm.includes(queryNorm);
    return tokens.every((t) => nameNorm.includes(t));
  }

  function globalRank(fig) {
    const idx = allFigures.findIndex((x) => x.name === fig.name);
    return idx >= 0 ? idx + 1 : 0;
  }

  function initials(name) {
    return name
      .split(" ")
      .map((p) => p[0])
      .slice(0, 2)
      .join("")
      .toUpperCase();
  }

  function cardEl(f, rank) {
    const article = document.createElement("article");
    article.className = "figure-card";
    article.dataset.figureName = f.name;
    article.tabIndex = 0;
    article.setAttribute("role", "button");
    article.setAttribute("aria-label", `Ver episódios com áudio de ${f.name}`);

    const thumb = document.createElement("div");
    thumb.className = "figure-thumb";

    if (f.imageUrl) {
      const img = document.createElement("img");
      img.src = f.imageUrl;
      img.alt = `Foto de ${f.name} (Wikipedia)`;
      img.loading = "lazy";
      thumb.appendChild(img);
    } else {
      const fb = document.createElement("span");
      fb.className = "figure-thumb-fallback";
      fb.setAttribute("aria-hidden", "true");
      fb.textContent = initials(f.name);
      thumb.appendChild(fb);
    }

    const badge = document.createElement("span");
    badge.className = "figure-rank";
    badge.textContent = String(rank);
    thumb.appendChild(badge);

    const h3 = document.createElement("h3");
    h3.className = "figure-name";
    h3.textContent = f.name;

    const meta = document.createElement("div");
    meta.className = "figure-meta";

    const countSpan = document.createElement("span");
    countSpan.className = "figure-count";
    const strong = document.createElement("strong");
    strong.textContent = String(f.count);
    countSpan.appendChild(strong);
    countSpan.appendChild(
      document.createTextNode(` ${f.count === 1 ? "aparição" : "aparições"}`)
    );

    const hitRate = f.hitRate ?? 0;
    const hitCount = f.hitCount ?? 0;
    const hitSpan = document.createElement("span");
    hitSpan.className = "figure-hit-rate";
    hitSpan.title = `Acertada em ${hitCount} de ${f.count} episódio${f.count === 1 ? "" : "s"}`;
    hitSpan.textContent = `${hitRate}% de acerto`;

    meta.appendChild(countSpan);
    meta.appendChild(hitSpan);

    article.appendChild(thumb);
    article.appendChild(h3);
    article.appendChild(meta);

    if (f.wikipediaUrl) {
      const wikiDiv = document.createElement("div");
      wikiDiv.className = "figure-wiki";
      const a = document.createElement("a");
      a.className = "figure-link";
      a.href = f.wikipediaUrl;
      a.target = "_blank";
      a.rel = "noopener noreferrer";
      a.innerHTML = 'Wikipédia <span aria-hidden="true">↗</span>';
      wikiDiv.appendChild(a);
      article.appendChild(wikiDiv);
    }

    return article;
  }

  function initFiguresSearch() {
    const grid = document.getElementById("figures-grid");
    const input = document.getElementById("figures-search");
    const hint = document.getElementById("figures-search-hint");
    const live = document.getElementById("figures-live");
    const empty = document.getElementById("figures-empty");

    if (!grid || !input || !hint || !live || !empty) {
      return;
    }

    const initialHTML = grid.innerHTML;

    function renderSubset(subset, rankFn) {
      grid.replaceChildren();
      for (let i = 0; i < subset.length; i++) {
        const f = subset[i];
        grid.appendChild(cardEl(f, rankFn(f)));
      }
    }

    function setEmpty(show) {
      empty.hidden = !show;
    }

    function updateLive(text) {
      live.textContent = text;
    }

    let debounce;

    function applyFilter() {
      const q = normalize(input.value);

      if (!q) {
        grid.innerHTML = initialHTML;
        hint.hidden = false;
        setEmpty(false);
        updateLive("");
        return;
      }

      hint.hidden = true;
      const matches = allFigures.filter((f) =>
        nameMatchesQuery(normalize(f.name), q)
      );

      if (matches.length === 0) {
        grid.replaceChildren();
        setEmpty(true);
        updateLive("Nenhuma figura encontrada.");
        return;
      }

      setEmpty(false);
      renderSubset(matches, globalRank);
      const noun = matches.length === 1 ? "figura" : "figuras";
      updateLive(
        `${matches.length} ${noun} encontrada${matches.length === 1 ? "" : "s"}.`
      );
    }

    function scheduleApply() {
      if (debounce) clearTimeout(debounce);
      debounce = setTimeout(() => {
        debounce = undefined;
        applyFilter();
      }, 140);
    }

    updateLive("");

    input.addEventListener("input", scheduleApply);
    input.addEventListener("search", scheduleApply);
  }

  function initFigureEpisodesTooltip() {
    const tooltip = document.getElementById("figure-episodes-tooltip");
    const listEl = document.getElementById("fig-tt-list");
    const nameEl = document.getElementById("fig-tt-name");
    const grid = document.getElementById("figures-grid");

    if (!tooltip || !listEl || !nameEl || !grid) return;

    let activeCard = null;
    let pinned = false;

    function buildListRows(rows) {
      listEl.replaceChildren();
      if (!rows || rows.length === 0) {
        const li = document.createElement("li");
        li.className = "fig-tt-empty";
        li.textContent = "Nenhum episódio com esta figura indexado.";
        listEl.appendChild(li);
        return;
      }
      for (let i = 0; i < rows.length; i++) {
        const ep = rows[i];
        const li = document.createElement("li");
        li.className = "fig-tt-item";

        const titleP = document.createElement("p");
        titleP.className = "fig-tt-item-title";
        titleP.textContent = ep.title;

        const meta = document.createElement("div");
        meta.className = "fig-tt-item-meta";

        const dateSpan = document.createElement("span");
        dateSpan.className = "fig-tt-item-date";
        dateSpan.textContent = ep.dateLabel || "";
        meta.appendChild(dateSpan);

        // Quem acertou
        const winners = ep.winners || [];
        if (winners.length > 0) {
          const winSpan = document.createElement("span");
          winSpan.className = "fig-tt-winner";

          const crownSvg = document.createElementNS("http://www.w3.org/2000/svg", "svg");
          crownSvg.setAttribute("width", "12");
          crownSvg.setAttribute("height", "12");
          crownSvg.setAttribute("viewBox", "0 0 64 64");
          crownSvg.setAttribute("aria-hidden", "true");
          crownSvg.style.flexShrink = "0";
          const crownPath = document.createElementNS("http://www.w3.org/2000/svg", "path");
          crownPath.setAttribute("fill", "#a87b00");
          crownPath.setAttribute("d", "M60,4H48c0-2.215-1.789-4-4-4H20c-2.211,0-4,1.785-4,4H4C1.789,4,0,5.785,0,8v8c0,8.836,7.164,16,16,16c0.188,0,0.363-0.051,0.547-0.059C17.984,37.57,22.379,41.973,28,43.43V56h-8c-2.211,0-4,1.785-4,4v4h32v-4c0-2.215-1.789-4-4-4h-8V43.43c5.621-1.457,10.016-5.859,11.453-11.488C47.637,31.949,47.812,32,48,32c8.836,0,16-7.164,16-16V8C64,5.785,62.211,4,60,4z M8,16v-4h8v12C11.582,24,8,20.414,8,16z M56,16c0,4.414-3.582,8-8,8V12h8V16z");
          crownSvg.appendChild(crownPath);

          winSpan.style.display = "inline-flex";
          winSpan.style.alignItems = "center";
          winSpan.style.gap = "4px";
          winSpan.appendChild(crownSvg);
          winSpan.appendChild(document.createTextNode(winners.join(" & ")));
          meta.appendChild(winSpan);
        } else {
          const noWin = document.createElement("span");
          noWin.className = "fig-tt-no-winner";
          noWin.textContent = "ninguém acertou";
          meta.appendChild(noWin);
        }

        const link = document.createElement("a");
        link.className = "fig-tt-spotify-btn";
        link.href = ep.spotifyUrl;
        link.target = "_blank";
        link.rel = "noopener noreferrer";
        link.innerHTML =
          'Ouvir no Spotify <span class="fig-tt-arrow" aria-hidden="true">↗</span>';

        li.appendChild(titleP);
        li.appendChild(meta);
        li.appendChild(link);
        listEl.appendChild(li);
      }
    }

    function showForCard(card) {
      const name = card.dataset.figureName;
      if (!name) return;

      nameEl.textContent = name;
      const rows = figureEpisodeIndex[name];
      buildListRows(rows);

      tooltip.style.visibility = "hidden";
      tooltip.style.display = "flex";
      const rect = card.getBoundingClientRect();
      const margin = 12;
      const tipRect = tooltip.getBoundingClientRect();
      let left = rect.left + rect.width / 2 - tipRect.width / 2;
      left = Math.max(margin, Math.min(window.innerWidth - tipRect.width - margin, left));
      let top = rect.top - tipRect.height - 12;
      if (top < margin) {
        top = rect.bottom + 12;
      }
      tooltip.style.position = "fixed";
      tooltip.style.left = `${left}px`;
      tooltip.style.top = `${top}px`;
      tooltip.style.visibility = "visible";
      tooltip.setAttribute("aria-hidden", "false");

      if (activeCard && activeCard !== card) activeCard.classList.remove("is-active");
      card.classList.add("is-active");
      activeCard = card;
    }

    function forceHide() {
      pinned = false;
      tooltip.style.display = "none";
      tooltip.setAttribute("aria-hidden", "true");
      if (activeCard) activeCard.classList.remove("is-active");
      activeCard = null;
    }

    grid.addEventListener("click", (e) => {
      const el = e.target;
      if (el.closest && el.closest("a.figure-link")) return;
      const card = el.closest && el.closest(".figure-card");
      if (!card || !grid.contains(card)) return;

      e.stopPropagation();

      if (pinned && activeCard === card) {
        forceHide();
        return;
      }
      pinned = true;
      showForCard(card);
    });

    grid.addEventListener("keydown", (e) => {
      if (e.key !== "Enter" && e.key !== " ") return;
      const el = e.target;
      const card = el.closest && el.closest(".figure-card");
      if (!card || !grid.contains(card)) return;
      if (el.closest && el.closest("a.figure-link")) return;
      e.preventDefault();
      pinned = true;
      showForCard(card);
    });

    document.addEventListener("click", (e) => {
      const el = e.target;
      if (el.closest && el.closest(".figure-card")) return;
      if (el.closest && el.closest("#figure-episodes-tooltip")) return;
      forceHide();
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") forceHide();
    });

    window.addEventListener(
      "scroll",
      () => {
        if (pinned && activeCard) showForCard(activeCard);
      },
      { passive: true }
    );

    window.addEventListener("resize", () => {
      if (pinned && activeCard) showForCard(activeCard);
    });
  }

  function initTopFigures() {
    initFiguresSearch();
    initFigureEpisodesTooltip();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initTopFigures);
  } else {
    initTopFigures();
  }
</script>

<style>
  .top-figures {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: 0 var(--page-padding) var(--section-gap);
    position: relative;
  }

  .figures-search-block {
    max-width: 420px;
    margin: 0 auto 28px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .figures-search-label {
    font-family: var(--font-ui);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(77, 59, 43, 0.6);
  }

  .figures-search-input {
    font-family: var(--font-ui);
    font-size: 15px;
    width: 100%;
    box-sizing: border-box;
    padding: 12px 14px;
    border: 1px solid var(--color-outline-soft);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    color: var(--color-primary-deep);
    outline: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .figures-search-input::placeholder {
    color: rgba(77, 59, 43, 0.45);
  }

  .figures-search-input:focus {
    border-color: rgba(77, 59, 43, 0.35);
    box-shadow: 0 0 0 3px var(--color-outline-faint);
  }

  .figures-search-hint {
    font-family: var(--font-ui);
    font-size: 13px;
    line-height: 1.45;
    color: rgba(77, 59, 43, 0.72);
    margin: 0;
  }

  .figures-live {
    font-family: var(--font-ui);
    font-size: 12px;
    color: var(--color-primary-deep);
    margin: 0;
    min-height: 1.35em;
    font-feature-settings: "tnum";
  }

  .figures-empty {
    font-family: var(--font-ui);
    font-size: 14px;
    text-align: center;
    color: rgba(77, 59, 43, 0.75);
    margin: 12px 0 0;
    padding: 24px 16px;
    border: 1px dashed var(--color-outline-soft);
    border-radius: var(--radius-xl);
    background: var(--color-surface-low);
  }

  .figures-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  /*
    Cards inseridos via JS não recebem data-astro-cid; :global faz o mesmo visual dos 20 SSR.
  */
  .figures-grid :global(.figure-card) {
    background: var(--color-surface);
    border-radius: var(--radius-xl);
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
    border: 1px solid var(--color-outline-faint);
    cursor: pointer;
  }

  .figures-grid :global(.figure-card:focus-visible) {
    outline: 2px solid var(--color-egg-yolk);
    outline-offset: 3px;
  }

  .figures-grid :global(.figure-card.is-active) {
    transform: translateY(-2px);
    box-shadow: 0 24px 50px -32px rgba(53, 37, 23, 0.45);
    border-color: rgba(235, 184, 61, 0.55);
  }

  .figures-grid :global(.figure-card:hover) {
    transform: translateY(-2px);
    box-shadow: 0 24px 50px -32px rgba(53, 37, 23, 0.4);
  }

  .figure-episodes-tooltip {
    position: fixed;
    display: none;
    flex-direction: column;
    z-index: 220;
    width: min(340px, calc(100vw - 24px));
    max-height: min(70vh, 520px);
    min-height: 0;
    overflow: hidden;
    background: var(--color-surface);
    border: 1px solid var(--color-outline-soft);
    border-radius: var(--radius-xl);
    padding: 16px 18px;
    box-shadow: 0 30px 60px -20px rgba(53, 37, 23, 0.25);
    color: var(--color-primary);
    pointer-events: auto;
  }

  .fig-tt-title {
    font-family: var(--font-ui);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    line-height: 1.35;
    color: var(--color-egg-yolk);
    margin: 0 0 10px;
  }

  .fig-tt-sub {
    font-family: var(--font-ui);
    font-size: 12px;
    color: rgba(77, 59, 43, 0.72);
    margin: 0 0 12px;
    line-height: 1.35;
  }

  .fig-tt-list {
    list-style: none;
    margin: 0;
    padding: 0;
    overflow-y: auto;
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding-right: 4px;
  }

  /*
    Itens da lista são criados no cliente (createElement): sem data-astro-cid,
    então precisam de :global para os estilos scoped pegarem (mesmo caso dos cards).
  */
  .figure-episodes-tooltip :global(.fig-tt-item) {
    padding-bottom: 14px;
    border-bottom: 1px solid var(--color-outline-faint);
  }

  .figure-episodes-tooltip :global(.fig-tt-item:last-child) {
    padding-bottom: 0;
    border-bottom: none;
  }

