---
import figures from "../data/figures.json";

interface Figure {
  name: string;
  count: number;
  wikipediaUrl?: string;
  imageUrl?: string;
  description?: string;
}

const top = (figures as Figure[]).slice(0, 12);
---

<section class="top-figures" id="figuras">
  <h2 class="section-title">Quem mais cai no ovo</h2>
  <p class="section-subtitle">
    Além de medir os apresentadores, dá para medir quem mais foi adivinhado.
    Estes são os personagens que a bancada ouviu falando mais vezes.
  </p>

  <div class="figures-grid">
    {top.map((f, i) => (
      <article class="figure-card">
        <div class="figure-thumb">
          {f.imageUrl ? (
            <img
              src={f.imageUrl}
              alt={`Foto de ${f.name} (Wikipedia)`}
              loading="lazy"
            />
          ) : (
            <span class="figure-thumb-fallback" aria-hidden="true">
              {f.name.split(" ").map((p) => p[0]).slice(0, 2).join("").toUpperCase()}
            </span>
          )}
          <span class="figure-rank">{i + 1}</span>
        </div>

        <h3 class="figure-name">{f.name}</h3>

        {f.description && (
          <p class="figure-desc">{f.description}</p>
        )}

        <div class="figure-meta">
          <span class="figure-count">
            <strong>{f.count}</strong> {f.count === 1 ? "aparição" : "aparições"}
          </span>
          {f.wikipediaUrl && (
            <a
              class="figure-link"
              href={f.wikipediaUrl}
              target="_blank"
              rel="noopener"
            >
              Wikipedia <span aria-hidden="true">↗</span>
            </a>
          )}
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .top-figures {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: 0 24px var(--section-gap);
  }

  .figures-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .figure-card {
    background: var(--color-surface);
    border-radius: var(--radius-xl);
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
    border: 1px solid var(--color-outline-faint);
  }

  .figure-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 24px 50px -32px rgba(53, 37, 23, 0.4);
  }

  .figure-thumb {
    position: relative;
    width: 96px;
    height: 96px;
    border-radius: 50%;
    overflow: hidden;
    margin: 0 auto 6px;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-outline-soft);
  }

  .figure-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .figure-thumb-fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-primary-deep);
  }

  .figure-rank {
    position: absolute;
    top: -4px;
    left: -4px;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: var(--color-primary-deep);
    color: var(--color-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-ui);
    font-size: 12px;
    font-weight: 600;
    border: 2px solid var(--color-bg);
    font-feature-settings: "tnum";
  }

  .figure-name {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--color-primary-deep);
    margin: 0;
    text-align: center;
    line-height: 1.2;
  }

  .figure-desc {
    font-family: var(--font-body);
    font-size: 12px;
    line-height: 1.4;
    color: rgba(77, 59, 43, 0.7);
    text-align: center;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .figure-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-top: auto;
    padding-top: 10px;
    border-top: 1px solid var(--color-outline-faint);
  }

  .figure-count {
    font-family: var(--font-ui);
    font-size: 12px;
    color: rgba(77, 59, 43, 0.7);
  }

  .figure-count strong {
    color: var(--color-primary-deep);
    font-feature-settings: "tnum";
  }

  .figure-link {
    font-family: var(--font-ui);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-primary-deep);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .figure-link:hover {
    color: var(--color-egg-yolk);
    border-bottom-color: var(--color-egg-yolk);
  }

  @media (max-width: 920px) {
    .figures-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 700px) {
    .figures-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
