---
import HeroCounters from "./HeroCounters.astro";

const base = import.meta.env.BASE_URL;
---

<section class="hero">
  <div class="hero-egg">
    <img src={`${base}/hero-kinder-ovo.png`} alt="Kinder Ovo de chocolate" />
  </div>

  <p class="kicker hero-kicker">Um ensaio sobre o Foro de Teresina</p>

  <h1 class="hero-title">Momento Kinder Ovo</h1>

  <p class="hero-dek">
    Desde 2018, ao fim de cada episódio do <em>Foro de Teresina</em>,
    a bancada escuta um áudio escolhido pela direção do programa e
    precisa adivinhar de quem é a voz surpresa. A gente contou todos esses ovos.
  </p>

  <HeroCounters />
</section>

<style>
  .hero {
    max-width: min(980px, 100%);
    margin: 0 auto;
    padding: 80px 24px var(--section-gap);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .hero-egg {
    width: min(620px, 96vw);
    margin-bottom: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-egg img {
    display: block;
    width: 100%;
    height: auto;
    max-height: min(440px, 56vh);
    object-fit: contain;
    filter: drop-shadow(0 20px 32px rgba(53, 37, 23, 0.2))
      drop-shadow(0 8px 16px rgba(53, 37, 23, 0.1));
  }

  .hero-kicker {
    margin-bottom: 24px;
    color: var(--color-primary-deep);
  }

  .hero-title {
    font-family: var(--font-hero-display), var(--font-body);
    font-weight: 600;
    font-size: clamp(2.65rem, 7vw, 4.85rem);
    line-height: 1.06;
    letter-spacing: -0.03em;
    color: var(--color-primary-deep);
    margin-bottom: 32px;
    max-width: 620px;
    font-variation-settings: "SOFT" 80, "WONK" 0;
  }

  .hero-dek {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 1rem;
    line-height: 1.6;
    color: rgba(77, 59, 43, 0.78);
    max-width: 480px;
  }

  .hero-dek em {
    font-style: italic;
  }
</style>
