---
interface Props {
  name: string;
  /** Caminho sob `public/guests/` (ex.: `bernardo-esteves.png`). */
  imageFile: string;
  profileUrl: string;
  size?: number;
}

const { name, imageFile, profileUrl, size = 64 } = Astro.props;
const base = import.meta.env.BASE_URL;
const isWikipedia = profileUrl.includes("wikipedia.org");
const linkLabel = isWikipedia
  ? `Página na Wikipédia de ${name} (abre em nova aba)`
  : `Perfil de ${name} no X (abre em nova aba)`;
---

<a
  class="guest-avatar-link"
  href={profileUrl}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={linkLabel}
>
  <div class="guest-avatar" style={`width:${size}px;height:${size}px`}>
    <img
      src={`${base}/guests/${imageFile}`}
      alt={`Retrato ilustrado de ${name}`}
      loading="lazy"
    />
  </div>
</a>

<style>
  .guest-avatar-link {
    display: inline-flex;
    flex-shrink: 0;
    text-decoration: none;
    border-radius: 50%;
    color: inherit;
    transition: transform 0.14s ease;
    cursor: pointer;
  }

  .guest-avatar-link:focus-visible {
    outline: 2px solid var(--color-egg-yolk);
    outline-offset: 3px;
  }

  .guest-avatar-link:hover .guest-avatar {
    border-color: var(--color-outline);
  }

  .guest-avatar-link:active {
    transform: scale(0.98);
  }

  .guest-avatar {
    flex-shrink: 0;
    border-radius: 50%;
    overflow: hidden;
    background: var(--color-surface);
    border: 2px solid var(--color-outline-soft);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .guest-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }
</style>
