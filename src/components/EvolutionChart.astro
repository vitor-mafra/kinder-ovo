---
import timeline from "../data/timeline.json";

const base = import.meta.env.BASE_URL;

const SLUGS: Record<string, string> = {
  "Fernando de Barros e Silva": "fernando-de-barros-e-silva",
  "José Roberto de Toledo": "jose-roberto-de-toledo",
  "Thais Bilenky": "thais-bilenky",
  "Ana Clara Costa": "ana-clara-costa",
  "Malu Gaspar": "malu-gaspar",
  "Celso Rocha de Barros": "celso-rocha-de-barros",
};

// All within the cocoa palette (no rainbow).
const COLORS: Record<string, string> = {
  "José Roberto de Toledo": "#352517",
  "Thais Bilenky": "#b85c3b",
  "Fernando de Barros e Silva": "#ebb83d",
  "Malu Gaspar": "#725a43",
  "Celso Rocha de Barros": "#8d735b",
  "Ana Clara Costa": "#b07a4c",
};

const series = timeline.cumulative.series;
const years = timeline.cumulative.years;

const W = 880;
const H = 360;
const PAD_TOP = 30;
const PAD_BOTTOM = 40;
const PAD_LEFT = 32;
const PAD_RIGHT = 110;

const maxY = Math.max(...series.flatMap((s) => s.data));
const yTicks = 5;
const yStep = Math.ceil(maxY / yTicks / 5) * 5;
const yMax = yStep * yTicks;

function xFor(i: number): number {
  if (years.length === 1) return PAD_LEFT;
  return PAD_LEFT + (i * (W - PAD_LEFT - PAD_RIGHT)) / (years.length - 1);
}

function yFor(v: number): number {
  return PAD_TOP + ((yMax - v) * (H - PAD_TOP - PAD_BOTTOM)) / yMax;
}

function pathFor(data: number[]): string {
  return data
    .map((v, i) => `${i === 0 ? "M" : "L"} ${xFor(i).toFixed(1)} ${yFor(v).toFixed(1)}`)
    .join(" ");
}

const annotations = [
  {
    text: "Toledo abre vantagem em 2021",
    year: 2021,
    name: "José Roberto de Toledo",
    dy: -42,
    dx: -110,
  },
  {
    text: "Thais entra em 2019 e ganha tração",
    year: 2020,
    name: "Thais Bilenky",
    dy: 36,
    dx: -120,
  },
];

const yAxisTicks = Array.from({ length: yTicks + 1 }, (_, i) => i * yStep);
---

<section class="evolution" id="evolucao">
  <h2 class="section-title">Quem dominou o ranking ao longo do tempo</h2>
  <p class="section-subtitle">
    Acertos acumulados, ano a ano. Toledo abriu vantagem cedo e a manteve;
    Celso veio em 2024 e já está mordendo o pódio.
  </p>

  <div class="chart-wrap">
    <svg viewBox={`0 0 ${W} ${H}`} class="chart" role="img" aria-label="Acertos acumulados por ano">
      {/* Grid + Y axis */}
      {yAxisTicks.map((v) => (
        <g>
          <line
            x1={PAD_LEFT}
            x2={W - PAD_RIGHT}
            y1={yFor(v)}
            y2={yFor(v)}
            stroke="rgba(77, 59, 43, 0.08)"
            stroke-width="1"
          />
          <text
            x={PAD_LEFT - 8}
            y={yFor(v) + 4}
            text-anchor="end"
            class="axis-label"
          >{v}</text>
        </g>
      ))}

      {/* X axis labels */}
      {years.map((y, i) => (
        <text
          x={xFor(i)}
          y={H - 16}
          text-anchor="middle"
          class="axis-label"
        >{y}</text>
      ))}

      {/* Lines */}
      {series.map((s) => (
        <path
          d={pathFor(s.data)}
          fill="none"
          stroke={COLORS[s.name] ?? "#352517"}
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      ))}

      {/* Annotations */}
      {annotations.map((a) => {
        const yearIdx = years.indexOf(a.year);
        if (yearIdx === -1) return null;
        const s = series.find((x) => x.name === a.name);
        if (!s) return null;
        const x = xFor(yearIdx);
        const y = yFor(s.data[yearIdx]);
        const tx = x + a.dx;
        const ty = y + a.dy;
        return (
          <g class="annotation">
            <line
              x1={x}
              y1={y}
              x2={tx + 4}
              y2={ty + 4}
              stroke="rgba(77, 59, 43, 0.4)"
              stroke-width="0.8"
              stroke-dasharray="2 2"
            />
            <circle cx={x} cy={y} r="3" fill="var(--color-egg-yolk)" />
            <text x={tx} y={ty} class="annotation-text">{a.text}</text>
          </g>
        );
      })}

      {/* End-of-line avatar markers */}
      {series.map((s) => {
        const lastIdx = s.data.length - 1;
        const cx = xFor(lastIdx);
        const cy = yFor(s.data[lastIdx]);
        const r = 18;
        const slug = SLUGS[s.name];
        const color = COLORS[s.name] ?? "#352517";
        return (
          <g>
            <circle cx={cx} cy={cy} r={r + 1.5} fill="var(--color-bg)" />
            <circle cx={cx} cy={cy} r={r} fill={color} fill-opacity="0.15" stroke={color} stroke-width="1.2" />
            <clipPath id={`clip-${slug}`}>
              <circle cx={cx} cy={cy} r={r - 1} />
            </clipPath>
            {slug && (
              <image
                href={`${base}/avatars/${slug}.png`}
                x={cx - r}
                y={cy - r}
                width={r * 2}
                height={r * 2}
                clip-path={`url(#clip-${slug})`}
                preserveAspectRatio="xMidYMid slice"
              />
            )}
            <text
              x={cx + r + 8}
              y={cy + 4}
              class="endpoint-label"
              fill={color}
            >{s.data[lastIdx]}</text>
          </g>
        );
      })}
    </svg>
  </div>
</section>

<style>
  .evolution {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: 0 24px var(--section-gap);
  }

  .chart-wrap {
    background: var(--color-surface);
    border: 1px solid var(--color-outline-soft);
    border-radius: var(--radius-xl);
    padding: 16px;
    overflow: hidden;
  }

  .chart {
    width: 100%;
    height: auto;
    display: block;
  }

  .axis-label {
    font-family: var(--font-ui);
    font-size: 11px;
    fill: rgba(77, 59, 43, 0.6);
  }

  .annotation-text {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 12px;
    fill: rgba(77, 59, 43, 0.85);
  }

  .endpoint-label {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 600;
    font-feature-settings: "tnum";
  }
</style>
