---
import rankings from "../data/rankings.json";
import episodes from "../data/episodes.json";
import GuestAvatar from "./GuestAvatar.astro";
import EggIcon from "./EggIcon.astro";

const SHOW_URL = "https://open.spotify.com/show/04bTe3UuVaZVDKV9ORFN4Y";

const GUEST_META: Record<string, { imageFile: string; profileUrl: string }> = {
  "Bernardo Esteves": {
    imageFile: "bernardo-esteves.png",
    profileUrl: "https://x.com/besteves",
  },
  "Marina Dias": {
    imageFile: "pinguim-colaborador.png",
    profileUrl: "https://x.com/falamarina",
  },
  "Thaís Oyama": {
    imageFile: "thais-oyama.png",
    profileUrl: "https://pt.wikipedia.org/wiki/Tha%C3%ADs_Oyama",
  },
  "Bernardo Mello Franco": {
    imageFile: "pinguim-colaborador.png",
    profileUrl: "https://x.com/BernardoMF",
  },
  "Luigi Maza": {
    imageFile: "luigi-maza.png",
    profileUrl: "https://x.com/LuigiMazzza",
  },
};

function spotifySearchUrl(title: string): string {
  return `https://open.spotify.com/search/${encodeURIComponent(title)}`;
}

function formatDate(iso: string): string {
  const d = new Date(iso);
  return d.toLocaleDateString("pt-BR", {
    day: "2-digit",
    month: "short",
    year: "numeric",
  });
}

interface EpisodeRef {
  episodeNumber: number | null;
  title: string;
  date: string;
  publicFigure: string | null;
  url: string;
}

const sortedEpisodes = [...episodes]
  .filter((e) => e.hasKinderOvo)
  .sort(
    (a, b) =>
      new Date(a.publishedAt).getTime() - new Date(b.publishedAt).getTime()
  );

function episodeRef(e: (typeof episodes)[number]): EpisodeRef {
  return {
    episodeNumber: e.episodeNumber,
    title: e.title,
    date: formatDate(e.publishedAt),
    publicFigure: e.publicFigure ?? null,
    url: spotifySearchUrl(e.title),
  };
}

const winsByName: Record<string, EpisodeRef[]> = {};
for (const ep of sortedEpisodes) {
  for (const w of ep.winners ?? []) {
    if (!winsByName[w]) winsByName[w] = [];
    winsByName[w].push(episodeRef(ep));
  }
}

const guestPanelists = rankings
  .filter(
    (r) =>
      !r.isMainPanelist && r.wins > 0 && Object.hasOwn(GUEST_META, r.name)
  )
  .sort((a, b) => b.wins - a.wins || a.name.localeCompare(b.name, "pt-BR"));
---

<section class="pictogram pictogram-guests" id="convidados-acertos">
  <h2 class="section-title">Convidados também acertam!</h2>

  <div class="pictogram-list">
    {guestPanelists.map((p) => {
      const meta = GUEST_META[p.name];
      const eps = winsByName[p.name] ?? [];
      return (
        <article class="row">
          <GuestAvatar
            name={p.name}
            imageFile={meta.imageFile}
            profileUrl={meta.profileUrl}
            size={64}
          />

          <div class="row-meta">
            <span class="row-name">{p.name}</span>
            <span class="row-acertos">
              <strong>{p.wins}</strong> acertos no quadro
            </span>
            <span class="row-rate">
              Taxa de vitória: <strong>{p.winRate}%</strong>
              <span class="row-rate-muted"> ({p.appearances} participações)</span>
            </span>
          </div>

          <div class="eggs">
            {eps.map((ep) => (
              <button
                type="button"
                class="guest-egg-btn"
                data-episode-number={ep.episodeNumber ?? ""}
                data-title={ep.title}
                data-date={ep.date}
                data-figure={ep.publicFigure ?? ""}
                data-url={ep.url}
                data-panelist={p.name}
                aria-label={`Episódio ${ep.episodeNumber ?? ""} — ${ep.title}`}
              >
                <EggIcon variant="filled" size={20} />
              </button>
            ))}
          </div>
        </article>
      );
    })}
  </div>

  <div id="guest-egg-tooltip" class="egg-tooltip" role="dialog" aria-hidden="true">
    <div class="tt-header">
      <span class="tt-kicker" id="guest-tt-panelist">—</span>
      <span class="tt-episode" id="guest-tt-episode">—</span>
    </div>
    <h3 class="tt-title" id="guest-tt-title">—</h3>
    <div class="tt-meta">
      <span id="guest-tt-date">—</span>
      <span class="tt-meta-sep" id="guest-tt-sep">·</span>
      <span class="tt-figure" id="guest-tt-figure">—</span>
    </div>
    <a class="tt-link" id="guest-tt-link" href={SHOW_URL} target="_blank" rel="noopener">
      Ouvir no Spotify
      <span class="tt-arrow" aria-hidden="true">↗</span>
    </a>
  </div>
</section>

<script>
  const tooltip = document.getElementById("guest-egg-tooltip");
  const ttPanelist = document.getElementById("guest-tt-panelist");
  const ttEpisode = document.getElementById("guest-tt-episode");
  const ttTitle = document.getElementById("guest-tt-title");
  const ttDate = document.getElementById("guest-tt-date");
  const ttSep = document.getElementById("guest-tt-sep");
  const ttFigure = document.getElementById("guest-tt-figure");
  const ttLink = document.getElementById("guest-tt-link") as HTMLAnchorElement | null;

  if (tooltip && ttPanelist && ttEpisode && ttTitle && ttDate && ttSep && ttFigure && ttLink) {
    let activeBtn: HTMLElement | null = null;
    let pinned = false;

    function showFor(btn: HTMLElement) {
      const number = btn.dataset.episodeNumber;
      const title = btn.dataset.title ?? "";
      const date = btn.dataset.date ?? "";
      const figure = btn.dataset.figure ?? "";
      const url = btn.dataset.url ?? "#";
      const panelist = btn.dataset.panelist ?? "";

      ttPanelist.textContent = `Acerto de ${panelist}`;
      ttEpisode.textContent = number ? `Episódio #${number}` : "";
      ttTitle.textContent = title;
      ttDate.textContent = date;
      if (figure) {
        ttSep.style.display = "";
        ttFigure.style.display = "";
        ttFigure.textContent = `Áudio de ${figure}`;
      } else {
        ttSep.style.display = "none";
        ttFigure.style.display = "none";
      }
      ttLink.href = url;

      const rect = btn.getBoundingClientRect();
      tooltip.style.visibility = "hidden";
      tooltip.style.display = "block";
      const tipRect = tooltip.getBoundingClientRect();
      const margin = 12;
      let left = rect.left + rect.width / 2 - tipRect.width / 2;
      left = Math.max(margin, Math.min(window.innerWidth - tipRect.width - margin, left));
      let top = rect.top + window.scrollY - tipRect.height - 12;
      if (top < window.scrollY + margin) {
        top = rect.bottom + window.scrollY + 12;
      }
      tooltip.style.left = `${left}px`;
      tooltip.style.top = `${top}px`;
      tooltip.style.visibility = "visible";
      tooltip.setAttribute("aria-hidden", "false");

      btn.classList.add("is-active");
      if (activeBtn && activeBtn !== btn) activeBtn.classList.remove("is-active");
      activeBtn = btn;
    }

    function hide() {
      if (pinned) return;
      tooltip.style.display = "none";
      tooltip.setAttribute("aria-hidden", "true");
      if (activeBtn) activeBtn.classList.remove("is-active");
      activeBtn = null;
    }

    document.querySelectorAll<HTMLElement>(".guest-egg-btn").forEach((btn) => {
      btn.addEventListener("mouseenter", () => {
        if (pinned) return;
        showFor(btn);
      });
      btn.addEventListener("focus", () => {
        if (pinned) return;
        showFor(btn);
      });
      btn.addEventListener("click", (e) => {
        e.preventDefault();
        if (pinned && activeBtn === btn) {
          pinned = false;
          hide();
          return;
        }
        pinned = true;
        showFor(btn);
      });
    });

    document.addEventListener("mouseover", (e) => {
      const target = e.target as HTMLElement;
      if (pinned) return;
      if (!target.closest(".guest-egg-btn") && !target.closest("#guest-egg-tooltip")) {
        hide();
      }
    });

    document.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      if (target.closest(".guest-egg-btn") || target.closest("#guest-egg-tooltip")) return;
      pinned = false;
      hide();
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        pinned = false;
        hide();
      }
    });

    window.addEventListener(
      "scroll",
      () => {
        if (!pinned) hide();
      },
      { passive: true }
    );
  }
</script>

<style>
  .pictogram-guests {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: 0 24px var(--section-gap);
  }

  .pictogram-guests .section-title {
    margin-bottom: 56px;
  }

  .pictogram-guests .pictogram-list {
    max-width: 920px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .pictogram-guests .row {
    display: grid;
    grid-template-columns: 64px 200px 1fr;
    gap: 12px 16px;
    align-items: start;
  }

  .pictogram-guests .row-meta {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }

  .pictogram-guests .row-name {
    font-family: var(--font-ui);
    font-size: 15px;
    font-weight: 600;
    color: var(--color-primary-deep);
  }

  .pictogram-guests .row-acertos {
    font-family: var(--font-ui);
    font-size: 13px;
    color: rgba(77, 59, 43, 0.78);
    line-height: 1.38;
  }

  .pictogram-guests .row-acertos strong {
    color: var(--color-primary-deep);
    font-weight: 700;
    font-feature-settings: "tnum";
  }

  .pictogram-guests .row-rate {
    font-family: var(--font-ui);
    font-size: 13px;
    color: var(--color-primary-deep);
    line-height: 1.42;
  }

  .pictogram-guests .row-rate strong {
    font-feature-settings: "tnum";
  }

  .pictogram-guests .row-rate-muted {
    color: rgba(77, 59, 43, 0.65);
    font-weight: 500;
    font-feature-settings: "tnum";
  }

  .pictogram-guests .eggs {
    display: flex;
    flex-wrap: wrap;
    gap: 4px 6px;
    align-content: flex-start;
    min-height: 32px;
  }

  .guest-egg-btn {
    appearance: none;
    margin: 0;
    border: none;
    background: transparent;
    font: inherit;
    cursor: pointer;
    box-sizing: border-box;
    color: var(--color-egg-chocolate);
    line-height: 0;
    border-radius: 4px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 3px;
    min-width: 28px;
    min-height: 28px;
    transition: transform 0.12s ease, color 0.12s ease;
  }

  .guest-egg-btn:hover,
  .guest-egg-btn:focus-visible,
  .guest-egg-btn.is-active {
    color: var(--color-egg-yolk);
    transform: translateY(-2px);
  }

  .guest-egg-btn:focus-visible {
    outline: 2px solid var(--color-egg-yolk);
    outline-offset: 2px;
  }

  .pictogram-guests .egg-tooltip {
    position: absolute;
    display: none;
    z-index: 200;
    width: 320px;
    background: var(--color-surface);
    border: 1px solid var(--color-outline-soft);
    border-radius: var(--radius-xl);
    padding: 16px 18px;
    box-shadow: 0 30px 60px -20px rgba(53, 37, 25, 0.25);
    color: var(--color-primary);
    pointer-events: auto;
  }

  .pictogram-guests .tt-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 8px;
  }

  .pictogram-guests .tt-kicker {
    font-family: var(--font-ui);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-egg-yolk);
  }

  .pictogram-guests .tt-episode {
    font-family: var(--font-ui);
    font-size: 11px;
    color: rgba(77, 59, 43, 0.6);
    font-feature-settings: "tnum";
  }

  .pictogram-guests .tt-title {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 500;
    line-height: 1.25;
    color: var(--color-primary-deep);
    margin: 0 0 8px;
  }

  .pictogram-guests .tt-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    font-family: var(--font-ui);
    font-size: 12px;
    color: rgba(77, 59, 43, 0.75);
    margin-bottom: 14px;
  }

  .pictogram-guests .tt-meta-sep {
    color: rgba(77, 59, 43, 0.4);
  }

  .pictogram-guests .tt-figure {
    color: var(--color-primary-deep);
    font-weight: 500;
  }

  .pictogram-guests .tt-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--color-egg-chocolate);
    color: var(--color-bg);
    font-family: var(--font-ui);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 8px 14px;
    border-radius: 999px;
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .pictogram-guests .tt-link:hover {
    background: var(--color-egg-yolk);
    color: var(--color-egg-chocolate);
  }

  .pictogram-guests .tt-arrow {
    font-size: 11px;
  }

  @media (max-width: 720px) {
    .pictogram-guests .row {
      grid-template-columns: minmax(84px, 96px) 1fr;
      gap: 14px;
    }

    .pictogram-guests .row .row-meta {
      grid-column: 2;
    }

    .pictogram-guests .row .eggs {
      grid-column: 1 / -1;
      margin-top: 10px;
    }

    .pictogram-guests .egg-tooltip {
      width: calc(100vw - 32px);
      max-width: 320px;
    }
  }
</style>
